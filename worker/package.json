{
  "name": "intentional-budget-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Read-only Plaid aggregation backend for the Intentional budgeting PWA (Cloudflare Worker + D1).",
  "scripts": {
    "test": "node test/run.mjs && node --experimental-sqlite test/integration.mjs",
    "dev": "wrangler dev",
    "db:local": "wrangler d1 execute intentional --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute intentional --remote --file=./schema.sql",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "4.103.0"
  }
}
